# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is in .gitignore.
#
# IMPORTANT: Read PLEASE_NOTE.md before filling in any values.
# Most keys here are intentionally blank because MealMate is being
# deployed to Google AI Studio, which injects credentials at runtime.

# ---------------------------------------------------------------------------
# Supabase — real auth + persistence (Phase 1)
# Only needed for self-hosted deployments outside Google AI Studio.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Base44 — current AI Planner backend (Phase 2)
# These will be replaced by VITE_GOOGLE_AI_API_KEY when the Google AI Studio
# migration is complete. Leave blank unless you are running Base44 locally.
# ---------------------------------------------------------------------------
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=
VITE_BASE44_FUNCTIONS_VERSION=
# Optional — usually obtained at runtime from URL params; set only for local dev.
VITE_BASE44_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Google AI Studio (future — Phase 3)
# This key will be injected automatically by Google AI Studio at deploy time.
# Do NOT hardcode a real key here. See PLEASE_NOTE.md for the migration plan.
# ---------------------------------------------------------------------------
VITE_GOOGLE_AI_API_KEY=

# ---------------------------------------------------------------------------
# Pricing API (optional — server-side only, not exposed to the browser)
# Configure in your Vercel / deployment environment, not in this file.
# ---------------------------------------------------------------------------
# PRICE_API_URL=
# PRICE_API_KEY=
# LULU_PRICE_API_URL=https://your-lulu-api/{query}
# CARREFOUR_PRICE_API_URL=https://your-carrefour-api/{query}
# MEGAMART_PRICE_API_URL=https://your-megamart-api/{query}
