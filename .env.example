# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is in .gitignore.
#
# See PLEASE_NOTE.md for why keys are intentionally blank.

# --- Google Gemini (AI Meal Planner) ---
# Intentionally empty — Google AI Studios injects this key at runtime.
# For local dev, get a free key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.0-flash

# --- Supabase (optional — cloud auth + persistence) ---
# The app works fully without Supabase, using localStorage as a fallback.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Legacy Base44 (no longer used) ---
# AI integration now goes directly through the Gemini REST API.
# VITE_BASE44_APP_ID=
# VITE_BASE44_APP_BASE_URL=
# VITE_BASE44_FUNCTIONS_VERSION=
