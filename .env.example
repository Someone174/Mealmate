# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is in .gitignore.
#
# See PLEASE_NOTE.md for a full explanation of why these are blank
# and how to set up for Google AI Studio deployment.

# ── AI Provider (choose one) ────────────────────────────────────────────────
# Set to "gemini" for Google AI Studio, or "base44" for the Base44 backend.
# Default is "base44" when this variable is not set.
VITE_AI_PROVIDER=

# ── Google AI Studio / Gemini ────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# When deploying to Google AI Studio the platform injects this automatically —
# DO NOT hard-code it here.
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-1.5-flash

# ── Base44 (legacy AI backend) ───────────────────────────────────────────────
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=
VITE_BASE44_FUNCTIONS_VERSION=
# Optional. Usually obtained at runtime from URL params; set only for local dev.
VITE_BASE44_ACCESS_TOKEN=

# ── Supabase (real auth + persistence) ──────────────────────────────────────
# Leave blank to run in local-only mode (data saved in browser localStorage).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
