# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is in .gitignore.
#
# !! READ PLEASE_NOTE.md before adding any API keys !!
# The Google AI API key is intentionally left blank — see that file for why.

# ─── Supabase (real auth + persistence) ──────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Base44 (current AI Planner backend) ─────────────────────────────────────
# Obtain from your Base44 project dashboard.
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=
VITE_BASE44_FUNCTIONS_VERSION=
# Optional. Usually obtained at runtime from URL params; set only for local dev.
VITE_BASE44_ACCESS_TOKEN=

# ─── Google AI Studios (future AI Planner backend) ───────────────────────────
# See PLEASE_NOTE.md — key is intentionally blank and will be injected by
# Google AI Studios at deploy time. Do NOT hardcode a key here.
VITE_GOOGLE_AI_API_KEY=
VITE_GOOGLE_AI_MODEL=gemini-2.0-flash

# ─── Price API (optional — app falls back to local estimates without these) ───
# POST endpoint that returns { prices: { item: { stores: {...} } } }
PRICE_API_URL=
PRICE_API_KEY=
